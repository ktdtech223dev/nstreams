{
  "name": "nstreams",
  "version": "1.0.9",
  "description": "N Streams — desktop streaming hub for the N Games crew",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "start": "electron .",
    "smoke": "node scripts/smoke-test.js",
    "dist": "npm run smoke && vite build && electron-builder"
  },
  "author": "N Games Crew",
  "license": "MIT",
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.14.1",
    "axios": "^1.6.0",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "cross-fetch": "^4.1.0",
    "date-fns": "^3.0.0",
    "electron-store": "^8.2.0",
    "express": "^4.18.2",
    "open": "^10.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.ngames.nstreams",
    "productName": "N Streams",
    "copyright": "© 2026 N Games Crew",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "public"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "protocols": [
      {
        "name": "N Streams",
        "schemes": [
          "nstreams"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "artifactName": "N-Streams-${version}-portable.${ext}"
    },
    "portable": {
      "artifactName": "N-Streams-${version}-portable.${ext}"
    }
  }
}
