{
  "appId": "com.ngames.nstreams",
  "productName": "N Streams",
  "files": [
    "dist/**/*",
    "electron/**/*",
    "public/**/*"
  ],
  "directories": {
    "output": "release"
  },
  "protocols": [
    {
      "name": "nstreams",
      "schemes": ["nstreams"]
    }
  ],
  "win": {
    "target": "nsis",
    "icon": "public/icon.png"
  },
  "mac": {
    "target": "dmg",
    "icon": "public/icon.png"
  },
  "linux": {
    "target": "AppImage",
    "icon": "public/icon.png"
  }
}
