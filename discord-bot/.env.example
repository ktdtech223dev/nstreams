# ── Discord ────────────────────────────────────────────────────────────────────
# 1. Go to https://discord.com/developers/applications → New Application → "N Games"
# 2. Bot tab → Add Bot → copy the Token below
# 3. OAuth2 tab → URL Generator → scope: bot + applications.commands
#    Bot permissions: Send Messages, Embed Links, Read Message History, Manage Messages (for pinning)
# 4. Visit the generated URL to add the bot to your server
DISCORD_TOKEN=

# Right-click your server name in Discord (with Developer Mode on) → Copy Server ID
DISCORD_GUILD_ID=

# Right-click the channel you want the bot to post in → Copy Channel ID
CHANNEL_BOT=

# ── Launcher server (pre-filled — don't change) ────────────────────────────────
LAUNCHER_WS=wss://ngames-server-production.up.railway.app
LAUNCHER_API=https://ngames-server-production.up.railway.app

# ── GitHub ─────────────────────────────────────────────────────────────────────
# Create a free PAT at https://github.com/settings/tokens → Generate new token (classic)
# No scopes needed for public repos. Boosts poll rate from 60 → 5,000 req/hr.
# Without it: polls every 8 min. With it: polls every 1 min.
GITHUB_TOKEN=

# ── Misc ───────────────────────────────────────────────────────────────────────
# Where to store seen-tags.json (last-seen GitHub tags) and state.json (pinned msg ID).
# Leave blank — defaults to /data on Railway or the bot's local directory.
#
# On Railway: add a persistent volume at /data:
#   Dashboard → discord-bot service → Volumes → + Add Volume → Mount path: /data
# Without a volume, the bot re-announces the latest release on every restart.
DATA_DIR=
